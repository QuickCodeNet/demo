{
  "Swagger": {
    "Title": "QuickCode - Demo - PricingEngineModule Api",
    "TermsOfService": "https://www.quickcode.net",
    "Contact": "https://www.quickcode.net",
    "License": "https://www.quickcode.net"
  },
  "Auditing": {
    "CaptureFullEntityOnUpdate": true,   
    "CaptureFullEntityOnInsert": true,   
    "CaptureFullEntityOnDelete": true
  },
  "CorsSettings": {
    "AllowOrigins": [ "http://localhost:3000", "http://localhost:6060", "http://quickcode-demo-gateway-api", "https://*.quickcode.net", "https://*.europe-west1.run.app" ]
  },
  "RateLimiting": {
    "Enabled": true,
    "ApplyAuthPolicies": false,
    "General": {
      "PermitLimit": 1000,
      "WindowSeconds": 60
    },
    "Auth": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    },
    "Refresh": {
      "PermitLimit": 60,
      "WindowSeconds": 60
    }
  }
}
