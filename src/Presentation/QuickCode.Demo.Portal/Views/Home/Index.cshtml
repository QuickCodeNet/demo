                                <div class="text-xs text-uppercase text-muted">Peak Hour</div>
                                <div class="h5 mb-0 font-weight-bold text-warning"><span id="peakHour24Hours" class="dashboard-skeleton">--:--</span></div>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="border rounded p-2 text-center">
                                <div class="text-xs text-uppercase text-muted">Peak Requests</div>
                                <div class="h5 mb-0 font-weight-bold text-warning"><span id="peakRequests24Hours" class="dashboard-skeleton">0</span></div>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="border rounded p-2 text-center">
                                <div class="text-xs text-uppercase text-muted">Failed Requests</div>
                                <div class="h5 mb-0 font-weight-bold text-danger"><span id="failedRequests24Hours" class="dashboard-skeleton">0</span></div>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="border rounded p-2 text-center">
                                <div class="text-xs text-uppercase text-muted">Success Rate</div>
                                <div class="h5 mb-0 font-weight-bold text-success"><span id="successRate24Hours" class="dashboard-skeleton">0%</span></div>
                            </div>
