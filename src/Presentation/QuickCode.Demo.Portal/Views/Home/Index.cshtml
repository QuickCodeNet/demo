                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row align-items-stretch">
        <div class="col-xl-8 col-lg-7">
            <div id="dailyRequestsCard" class="card shadow mb-4 dashboard-card-loading">
                <span class="dashboard-loading-spinner"></span>
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Daily HTTP Request Stats (Last 7 Days) - <span class="selected-module-title">@Model.SelectedModule</span></h6>
                </div>
                <div class="card-body">
                    <div class="chart-area" style="height: -webkit-fill-available;max-height: 400px;">
                        <canvas id="dailyRequestsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-lg-5">
            <div id="operationalSevenDaysCard" class="card shadow mb-4 dashboard-card-loading">
                <span class="dashboard-loading-spinner"></span>
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Last 7 Days Operational Insights</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-6 mb-3">
                            <div class="border rounded p-2 text-center">
                                <div class="text-xs text-uppercase text-muted">Requests</div>
                                <div class="h5 mb-0 font-weight-bold text-primary"><span id="requestsSevenDays" class="dashboard-skeleton">0</span></div>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="border rounded p-2 text-center">
                                <div class="text-xs text-uppercase text-muted">Active Modules</div>
                                <div class="h5 mb-0 font-weight-bold text-info"><span id="activeModulesSevenDays" class="dashboard-skeleton">0</span></div>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="border rounded p-2 text-center">
                                <div class="text-xs text-uppercase text-muted">Peak Day</div>
                                <div class="h5 mb-0 font-weight-bold text-warning"><span id="peakDaySevenDays" class="dashboard-skeleton">-</span></div>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="border rounded p-2 text-center">
                                <div class="text-xs text-uppercase text-muted">Peak Requests</div>
                                <div class="h5 mb-0 font-weight-bold text-warning"><span id="peakRequestsSevenDays" class="dashboard-skeleton">0</span></div>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="border rounded p-2 text-center">
                                <div class="text-xs text-uppercase text-muted">Failed Requests</div>
                                <div class="h5 mb-0 font-weight-bold text-danger"><span id="failedRequestsSevenDays" class="dashboard-skeleton">0</span></div>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="border rounded p-2 text-center">
                                <div class="text-xs text-uppercase text-muted">Success Rate</div>
                                <div class="h5 mb-0 font-weight-bold text-success"><span id="successRateSevenDays" class="dashboard-skeleton">0%</span></div>
                            </div>
                        </div>
                    </div>
                    <hr class="mt-1 mb-3" />
                    <div class="small text-uppercase text-muted mb-2">Module Totals (7 Days)</div>
                    <div id="moduleTotalsList">
                        <div class="dashboard-skeleton w-100">&nbsp;</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="moduleDailySeriesContainer"></div>

    <div class="row">
        <div class="col-xl-8 mb-4">
            <div id="durationTrendCard" class="card shadow h-100 dashboard-card-loading">
                <span class="dashboard-loading-spinner"></span>
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Duration Trends (Avg / Max / Min) - Milliseconds</h6></div>
                <div class="card-body"><div class="chart-area"><canvas id="durationTrendChart"></canvas></div></div>
            </div>
        </div>
        <div class="col-xl-4 mb-4">
            <div id="statusCodeCard" class="card shadow h-100 dashboard-card-loading">
                <span class="dashboard-loading-spinner"></span>
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">HTTP Status Code Distribution - <span class="selected-module-title">@Model.SelectedModule</span></h6></div>
                <div class="card-body"><div class="chart-area"><canvas id="statusCodeChart"></canvas></div></div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div id="dailyDetailsCard" class="card shadow h-100 dashboard-card-loading">
                <span class="dashboard-loading-spinner"></span>
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Daily Request Details</h6>
                </div>
                <div class="card-body py-2">
                    <div class="table-responsive dashboard-table-scroll dashboard-top-services-scroll">
                        <table class="table table-sm table-bordered table-hover mb-0 small dashboard-compact-table">
                            <thead class="thead-light">
                                <tr>
                                    <th>Day</th>
                                    <th>Total Requests</th>
                                    <th>Avg (ms)</th>
                                    <th>Max (ms)</th>
                                    <th>Min (ms)</th>
                                </tr>
                            </thead>
                            <tbody id="dailyRequestDetailsBody">
                                <tr>
                                    <td colspan="5"><span class="dashboard-skeleton w-100">&nbsp;</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div id="topServicesCard" class="card shadow h-100 dashboard-card-loading">
                <span class="dashboard-loading-spinner"></span>
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Top Called Service by Module (Last 7 Days) - <span class="selected-module-title">@Model.SelectedModule</span></h6>
                </div>
                <div class="card-body py-2">
                    <div class="table-responsive dashboard-table-scroll">
                        <table class="table table-sm table-bordered table-hover mb-0 small dashboard-compact-table">
                            <thead class="thead-light">
                                <tr>
                                    <th>Module</th>
                                    <th>Service</th>
                                    <th>Total Requests</th>
                                </tr>
                            </thead>
                            <tbody id="topServicesBody">
                                <tr>
                                    <td colspan="3"><span class="dashboard-skeleton w-100">&nbsp;</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.0.1/dist/chart.umd.min.js"></script>
<script>
    const dashboardSummaryUrl = '@Url.Action("DashboardSummary", "Home")';
    const dashboardHourlyUrl = '@Url.Action("DashboardHourlyMetrics", "Home")';
    const dashboardSevenDayUrl = '@Url.Action("DashboardSevenDayMetrics", "Home")';
    const dashboardStatusUrl = '@Url.Action("DashboardStatusMetrics", "Home")';
    const dashboardTopServicesUrl = '@Url.Action("DashboardTopServices", "Home")';
    const modulePalette = ['#4e73df', '#1cc88a', '#f6c23e', '#e74a3b', '#36b9cc', '#858796', '#5a5c69', '#6610f2', '#fd7e14', '#20c997'];
    let hourlyRequestsChart;
    let dailyRequestsChart;
    let durationTrendChart;
    let statusCodeChart;
    let moduleDailyCharts = [];
    const dashboardState = {
        selectedModule: '@Model.SelectedModule',
        hourLabels: [],
        moduleHourlySeries: [],
        totalHourlyTotals: [],
        statusStats24Hours: [],
        dailyStats: [],
        totalDailyStats: [],
        moduleDailySeries: [],
        moduleTotals: [],
        statusStats: [],
        topServices: []
    };

    const readProp = (item, name) => item?.[name] ?? item?.[name.charAt(0).toLowerCase() + name.slice(1)];
    const readArray = (item, name) => readProp(item, name) || [];
    const readNumber = (item, name) => Number(readProp(item, name) || 0);
    const trimModuleSuffix = value => (value || '').replace(/\s+module$/i, '');
    const encodeModule = () => encodeURIComponent(document.getElementById('selectedModule')?.value || 'All Modules');
    const metricCardIds = ['hourlyRequestsCard', 'dailyRequestsCard', 'operational24HoursCard', 'operationalSevenDaysCard', 'durationTrendCard', 'statusCodeCard', 'dailyDetailsCard', 'topServicesCard'];
    const setCardLoading = (id, isLoading) => {
        const card = document.getElementById(id);
        if (!card) return;
        card.classList.toggle('dashboard-card-loading', isLoading);
        const spinner = card.querySelector('.dashboard-loading-spinner');
        if (spinner) spinner.style.display = isLoading ? '' : 'none';
    };
    const setMetricCardsLoading = (isLoading) => metricCardIds.forEach(id => setCardLoading(id, isLoading));
    const setText = (id, value) => {
        const el = document.getElementById(id);
        if (!el) return;
        el.classList.remove('dashboard-skeleton');
        el.textContent = value;
    };
    const setLoadingText = (id) => {
        const el = document.getElementById(id);
        if (!el) return;
        el.classList.add('dashboard-skeleton');
        el.textContent = '0';
    };
    const getStatusText = (code) => {
        if (code >= 200 && code <= 299) return 'Success';
        if (code >= 300 && code <= 399) return 'Redirect';
        if (code >= 400 && code <= 499) return 'Client Error';
        if (code >= 500 && code <= 599) return 'Server Error';
        return 'Unknown';
    };
    const getEmptyLast24HourLabels = () => Array.from({ length: 24 }, () => '');

    const createCharts = () => {
        const hourlyCtx = document.getElementById('hourlyRequestsChart');
        if (hourlyCtx) {
            hourlyRequestsChart = new Chart(hourlyCtx, {
                type: 'line',
                data: { labels: getEmptyLast24HourLabels(), datasets: [] },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: { beginAtZero: true, title: { display: true, text: 'Requests' } }
                    },
                    plugins: { legend: { position: 'bottom' } }
                }
            });
        }

        const ctx = document.getElementById('dailyRequestsChart');
        if (ctx) {
            dailyRequestsChart = new Chart(ctx, {
                type: 'bar',
                data: { labels: [], datasets: [{ label: 'Total Requests', data: [], backgroundColor: 'rgba(78, 115, 223, 0.65)', borderColor: 'rgba(78, 115, 223, 1)', borderWidth: 1, yAxisID: 'y' }] },
                options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true, title: { display: true, text: 'Requests' } } } }
            });
        }

        const durationCtx = document.getElementById('durationTrendChart');
        if (durationCtx) {
            durationTrendChart = new Chart(durationCtx, {
                type: 'line',
                data: {
                    labels: [],
                    datasets: [
                        { label: 'Avg (ms)', data: [], borderColor: 'rgba(54, 185, 204, 1)', backgroundColor: 'rgba(54, 185, 204, 0.15)', tension: 0, cubicInterpolationMode: 'monotone' },
                        { label: 'Max (ms)', data: [], borderColor: 'rgba(246, 194, 62, 1)', backgroundColor: 'rgba(246, 194, 62, 0.15)', tension: 0, cubicInterpolationMode: 'monotone' },
                        { label: 'Min (ms)', data: [], borderColor: 'rgba(28, 200, 138, 1)', backgroundColor: 'rgba(28, 200, 138, 0.15)', tension: 0, cubicInterpolationMode: 'monotone' }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: { y: { beginAtZero: true, min: 0, title: { display: true, text: 'Milliseconds' } } },
                    plugins: { tooltip: { callbacks: { label: context => `${context.dataset.label}: ${Number(context.raw || 0).toFixed(2)} ms` } } }
                }
            });
        }

        const statusCtx = document.getElementById('statusCodeChart');
        if (statusCtx) {
            statusCodeChart = new Chart(statusCtx, {
                type: 'doughnut',
                data: { labels: [], datasets: [{ data: [], backgroundColor: ['#4e73df', '#1cc88a', '#f6c23e', '#e74a3b', '#36b9cc', '#858796'] }] },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        tooltip: { callbacks: { label: context => `${context.label}: ${Number(context.raw || 0)} requests` } },
                        legend: { position: 'bottom' }
                    }
                }
            });
        }
    };

    const setMetricLoading = () => {
        setMetricCardsLoading(true);
        ['requests24Hours', 'activeModules24Hours', 'peakHour24Hours', 'peakRequests24Hours', 'requestsSevenDays', 'avgDurationSevenDays', 'maxDurationSevenDays', 'minDurationSevenDays', 'recentSuccessRate'].forEach(setLoadingText);
        document.getElementById('moduleTotalsList').innerHTML = '<div class="dashboard-skeleton w-100">&nbsp;</div>';
        document.getElementById('dailyRequestDetailsBody').innerHTML = '<tr><td colspan="5"><span class="dashboard-skeleton w-100">&nbsp;</span></td></tr>';
        document.getElementById('topServicesBody').innerHTML = '<tr><td colspan="3"><span class="dashboard-skeleton w-100">&nbsp;</span></td></tr>';
    };

    const updateSummary = async () => {
        const response = await fetch(`${dashboardSummaryUrl}?selectedModule=${encodeModule()}`);
        if (!response.ok) throw new Error('Dashboard summary request failed.');
        const data = await response.json();
        setText('totalModules', readProp(data, 'TotalModules') ?? 0);
        setText('totalEndpoints', readProp(data, 'TotalEndpoints') ?? 0);
        setText('totalPermissionGroups', readProp(data, 'TotalPermissionGroups') ?? 0);
        setText('totalUsers', readProp(data, 'TotalUsers') ?? 0);
    };

    const updateDailyRequestsChart = (labels, counts, moduleDailySeries, totalDailyStats) => {
        if (!dailyRequestsChart) return;
        const nonEmptyModuleSeries = (moduleDailySeries || [])
            .filter(series => readArray(series, 'DailyTotals').some(value => Number(value || 0) > 0));
        const moduleDatasets = nonEmptyModuleSeries.map((series, index) => {
            const totals = readArray(series, 'DailyTotals');
            const module = readProp(series, 'Module') || '';
            return {
                label: `${module} (${totals.reduce((sum, value) => sum + Number(value || 0), 0)})`,
                data: totals,
                borderColor: modulePalette[index % modulePalette.length],
                backgroundColor: 'transparent',
                borderWidth: 2,
                tension: 0.2,
                type: 'line',
                yAxisID: 'y'
            };
        });
        dailyRequestsChart.data.labels = labels;
        const totalCounts = Array.isArray(totalDailyStats) && totalDailyStats.length
            ? totalDailyStats.map(i => readNumber(i, 'TotalRequests'))
            : counts;
        const totalDataset = {
            label: `Total Requests (${totalCounts.reduce((sum, value) => sum + Number(value || 0), 0)})`,
            data: totalCounts,
            backgroundColor: 'rgba(78, 115, 223, 0.18)',
            borderColor: 'rgba(78, 115, 223, 1)',
            borderWidth: 2,
            type: moduleDatasets.length ? 'line' : 'bar',
            tension: 0.15,
            yAxisID: 'y'
        };
        dailyRequestsChart.data.datasets = [totalDataset, ...moduleDatasets];
        dailyRequestsChart.update();
    };

    const updateHourlyRequestsChart = (hourLabels, moduleHourlySeries, totalHourlyTotals) => {
        if (!hourlyRequestsChart) return;
        hourlyRequestsChart.data.labels = Array.isArray(hourLabels) && hourLabels.length === 24
            ? hourLabels
            : getEmptyLast24HourLabels();
        const nonEmptyModuleSeries = (moduleHourlySeries || [])
            .filter(series => readArray(series, 'HourlyTotals').some(value => Number(value || 0) > 0));
        const moduleDatasets = nonEmptyModuleSeries.map((series, index) => {
            const totals = readArray(series, 'HourlyTotals');
            const module = readProp(series, 'Module') || '';
            return {
                label: `${module} (${totals.reduce((sum, value) => sum + Number(value || 0), 0)})`,
                data: totals,
                borderColor: modulePalette[index % modulePalette.length],
                backgroundColor: 'transparent',
                borderWidth: 2,
                tension: 0.25
            };
        });
        const globalHourlyTotals = Array.isArray(totalHourlyTotals) && totalHourlyTotals.length
            ? totalHourlyTotals
            : hourlyRequestsChart.data.labels.map((_, index) =>
                (moduleHourlySeries || []).reduce((sum, series) => sum + Number(readArray(series, 'HourlyTotals')[index] || 0), 0));
        const totalDataset = {
            label: `Total Requests (${globalHourlyTotals.reduce((sum, value) => sum + Number(value || 0), 0)})`,
            data: globalHourlyTotals,
            borderColor: 'rgba(78, 115, 223, 1)',
            backgroundColor: 'rgba(78, 115, 223, 0.14)',
            borderWidth: 2,
            tension: 0.2
        };
        hourlyRequestsChart.data.datasets = [totalDataset, ...moduleDatasets];
        hourlyRequestsChart.update();
    };

    const updateModuleDailyCharts = (labels, selectedModule, moduleDailySeries) => {
        moduleDailyCharts.forEach(chart => chart.destroy());
        moduleDailyCharts = [];
        const container = document.getElementById('moduleDailySeriesContainer');
        if (!container) return;
        container.innerHTML = '';
        if ((selectedModule || '').toLowerCase() !== 'all modules' || !Array.isArray(moduleDailySeries) || moduleDailySeries.length === 0) return;

        const row = document.createElement('div');
        row.className = 'row';
        moduleDailySeries.forEach((series, index) => {
            const totals = readArray(series, 'DailyTotals');
            const module = readProp(series, 'Module') || '';
            const total = totals.reduce((sum, value) => sum + Number(value || 0), 0);
            const col = document.createElement('div');
            col.className = 'col-xl-6 mb-4';
            col.innerHTML = `<div class="card shadow h-100"><div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">${module} (${total})</h6></div><div class="card-body"><div class="chart-area"><canvas id="moduleDailyChart_${index}"></canvas></div></div></div>`;
            row.appendChild(col);
        });
        container.appendChild(row);

        moduleDailySeries.forEach((series, index) => {
            const canvas = document.getElementById(`moduleDailyChart_${index}`);
            if (!canvas) return;
            const totals = readArray(series, 'DailyTotals');
            const module = readProp(series, 'Module') || '';
            moduleDailyCharts.push(new Chart(canvas, {
                type: 'line',
                data: { labels, datasets: [{ label: `${module} (${totals.reduce((sum, value) => sum + Number(value || 0), 0)})`, data: totals, borderColor: modulePalette[index % modulePalette.length], backgroundColor: 'transparent', borderWidth: 2, tension: 0.2 }] },
                options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true, title: { display: true, text: 'Requests' } } } }
            }));
        });
    };

    const updateDurationChart = (labels, dailyStats) => {
        if (!durationTrendChart) return;
        durationTrendChart.data.labels = labels;
        durationTrendChart.data.datasets[0].data = dailyStats.map(i => Math.max(0, Number(readProp(i, 'AvgDurationMs') || 0)));
        durationTrendChart.data.datasets[1].data = dailyStats.map(i => Math.max(0, Number(readProp(i, 'MaxDurationMs') || 0)));
        durationTrendChart.data.datasets[2].data = dailyStats.map(i => Math.max(0, Number(readProp(i, 'MinDurationMs') || 0)));
        durationTrendChart.update();
    };

    const updateStatusChart = (statusItems) => {
        if (!statusCodeChart) return;
        const statusTotal = statusItems.reduce((sum, item) => sum + readNumber(item, 'TotalRequests'), 0);
        const getStatusPercent = count => statusTotal > 0 ? ((Number(count || 0) * 100) / statusTotal).toFixed(1) : '0.0';
        statusCodeChart.data.labels = statusItems.map(item => {
            const code = readNumber(item, 'StatusCode');
            const count = readNumber(item, 'TotalRequests');
            return `${code} ${getStatusText(code)} - ${count} (${getStatusPercent(count)}%)`;
        });
        statusCodeChart.data.datasets[0].data = statusItems.map(item => readNumber(item, 'TotalRequests'));
        statusCodeChart.update();
    };

    const renderModuleTotalsList = (targetId, items, emptyText) => {
        const target = document.getElementById(targetId);
        if (!target) return;
        target.innerHTML = '';
        if (!items.length) {
            target.innerHTML = `<div class="small text-muted">${emptyText}</div>`;
            return;
        }
        items.slice(0, 6).forEach(item => {
            const row = document.createElement('div');
            row.className = 'd-flex justify-content-between small mb-1';
            row.innerHTML = `<span>${readProp(item, 'Module') || ''}</span><strong>${readNumber(item, 'TotalRequests')}</strong>`;
            target.appendChild(row);
        });
    };

    const renderOperationalInsights = () => {
        const dailyStats = dashboardState.dailyStats;
        const statusStats = dashboardState.statusStats;
        const statusStats24Hours = dashboardState.statusStats24Hours;
        const moduleTotals = dashboardState.moduleTotals;
        const moduleHourlySeries = dashboardState.moduleHourlySeries;
        const hourLabels = dashboardState.hourLabels;

        const hourlyTotals = Array.isArray(dashboardState.totalHourlyTotals) && dashboardState.totalHourlyTotals.length
            ? dashboardState.totalHourlyTotals
            : Array.from({ length: 24 }, (_, index) =>
                moduleHourlySeries.reduce((sum, series) => sum + Number((readArray(series, 'HourlyTotals')[index]) || 0), 0));
        const total24Hours = hourlyTotals.reduce((sum, value) => sum + value, 0);
        const peakRequests = hourlyTotals.length ? Math.max(...hourlyTotals) : 0;
        const peakIndex = hourlyTotals.indexOf(peakRequests);
        const activeModules = moduleHourlySeries.filter(series =>
            readArray(series, 'HourlyTotals').reduce((sum, value) => sum + Number(value || 0), 0) > 0).length;
        const failedRequests24Hours = statusStats24Hours
            .filter(item => readNumber(item, 'StatusCode') >= 400)
            .reduce((sum, item) => sum + readNumber(item, 'TotalRequests'), 0);
        const totalStatusRequests24Hours = statusStats24Hours
            .reduce((sum, item) => sum + readNumber(item, 'TotalRequests'), 0);
        const successRate24Hours = totalStatusRequests24Hours > 0
            ? (((totalStatusRequests24Hours - failedRequests24Hours) * 100) / totalStatusRequests24Hours).toFixed(1)
            : '0.0';

        const totalDailyStats = Array.isArray(dashboardState.totalDailyStats) && dashboardState.totalDailyStats.length
            ? dashboardState.totalDailyStats
            : dailyStats;
        const totalLastSevenDays = totalDailyStats.reduce((sum, item) => sum + readNumber(item, 'TotalRequests'), 0);
        const activeModulesSevenDays = moduleTotals.filter(item => readNumber(item, 'TotalRequests') > 0).length;
        const peakDayItem = totalDailyStats.reduce((peak, item) =>
            readNumber(item, 'TotalRequests') > readNumber(peak, 'TotalRequests') ? item : peak, {});
        const peakDayRequests = readNumber(peakDayItem, 'TotalRequests');
        const failedRequestsSevenDays = statusStats
            .filter(item => readNumber(item, 'StatusCode') >= 400)
            .reduce((sum, item) => sum + readNumber(item, 'TotalRequests'), 0);
        const totalStatusRequestsSevenDays = statusStats
            .reduce((sum, item) => sum + readNumber(item, 'TotalRequests'), 0);
        const successRateSevenDays = totalStatusRequestsSevenDays > 0
            ? (((totalStatusRequestsSevenDays - failedRequestsSevenDays) * 100) / totalStatusRequestsSevenDays).toFixed(1)
            : '0.0';

        setText('requests24Hours', total24Hours);
        setText('activeModules24Hours', activeModules);
        setText('peakHour24Hours', peakRequests > 0 ? (hourLabels[peakIndex] || '--:--') : '--:--');
        setText('peakRequests24Hours', peakRequests);
        setText('failedRequests24Hours', failedRequests24Hours);
        setText('successRate24Hours', `${successRate24Hours}%`);
        setText('requestsSevenDays', totalLastSevenDays);
        setText('activeModulesSevenDays', activeModulesSevenDays);
        setText('peakDaySevenDays', peakDayRequests > 0 ? (readProp(peakDayItem, 'RequestDay') || '-') : '-');
        setText('peakRequestsSevenDays', peakDayRequests);
        setText('failedRequestsSevenDays', failedRequestsSevenDays);
        setText('successRateSevenDays', `${successRateSevenDays}%`);

        const moduleTotals24Hours = moduleHourlySeries
            .map(series => ({
                Module: readProp(series, 'Module') || '',
                TotalRequests: readArray(series, 'HourlyTotals').reduce((sum, value) => sum + Number(value || 0), 0)
            }))
            .filter(item => item.Module)
            .sort((left, right) => Number(right.TotalRequests || 0) - Number(left.TotalRequests || 0));

        renderModuleTotalsList('moduleTotals24HoursList', moduleTotals24Hours, 'No module totals in the last 24 hours yet.');
        renderModuleTotalsList('moduleTotalsList', moduleTotals, 'No module totals yet.');
    };

    const renderTables = (dailyStats, topServices) => {
        const dailyBody = document.getElementById('dailyRequestDetailsBody');
        dailyBody.innerHTML = dailyStats.length ? '' : '<tr><td colspan="5" class="text-center text-muted">No request statistics yet.</td></tr>';
        dailyStats.forEach(stat => dailyBody.insertAdjacentHTML('beforeend', `<tr><td>${readProp(stat, 'RequestDay') || ''}</td><td>${readNumber(stat, 'TotalRequests')}</td><td>${Number(readProp(stat, 'AvgDurationMs') || 0).toFixed(2)}</td><td>${readNumber(stat, 'MaxDurationMs')}</td><td>${readNumber(stat, 'MinDurationMs')}</td></tr>`));

        const topBody = document.getElementById('topServicesBody');
        topBody.innerHTML = topServices.length ? '' : '<tr><td colspan="3" class="text-center text-muted">No service stats yet.</td></tr>';
        topServices.forEach(service => topBody.insertAdjacentHTML('beforeend', `<tr><td>${trimModuleSuffix(readProp(service, 'Module'))}</td><td><span class="badge badge-light">${readProp(service, 'Method') || ''}</span> ${readProp(service, 'Path') || ''}</td><td>${readNumber(service, 'TotalRequests')}</td></tr>`));
    };

    const updateHourlyMetrics = async () => {
        ['hourlyRequestsCard', 'operational24HoursCard'].forEach(id => setCardLoading(id, true));
        try {
            const response = await fetch(`${dashboardHourlyUrl}?selectedModule=${encodeModule()}`);
            if (!response.ok) throw new Error('Dashboard hourly metrics request failed.');
            const data = await response.json();
            dashboardState.selectedModule = readProp(data, 'SelectedModule') || 'All Modules';
            dashboardState.hourLabels = readArray(data, 'Last24HourLabels');
            dashboardState.moduleHourlySeries = readArray(data, 'ModuleHourlySeries');
            dashboardState.totalHourlyTotals = readArray(data, 'TotalHourlyTotals');
            dashboardState.statusStats24Hours = readArray(data, 'StatusCodeStats');
            document.querySelectorAll('.selected-module-title').forEach(el => el.textContent = dashboardState.selectedModule);
            updateHourlyRequestsChart(dashboardState.hourLabels, dashboardState.moduleHourlySeries, dashboardState.totalHourlyTotals);
            renderOperationalInsights();
        } finally {
            ['hourlyRequestsCard', 'operational24HoursCard'].forEach(id => setCardLoading(id, false));
        }
    };

    const updateSevenDayMetrics = async () => {
        ['dailyRequestsCard', 'operationalSevenDaysCard', 'durationTrendCard', 'dailyDetailsCard'].forEach(id => setCardLoading(id, true));
        try {
            const response = await fetch(`${dashboardSevenDayUrl}?selectedModule=${encodeModule()}`);
            if (!response.ok) throw new Error('Dashboard seven day metrics request failed.');
            const data = await response.json();
            dashboardState.selectedModule = readProp(data, 'SelectedModule') || dashboardState.selectedModule;
            dashboardState.dailyStats = readArray(data, 'DailyRequestStats');
            dashboardState.totalDailyStats = readArray(data, 'TotalDailyRequestStats');
            dashboardState.moduleDailySeries = readArray(data, 'ModuleDailySeries');
            dashboardState.moduleTotals = readArray(data, 'ModuleTotalRequests');
            const labelSource = dashboardState.totalDailyStats.length ? dashboardState.totalDailyStats : dashboardState.dailyStats;
            const labels = labelSource.map(i => readProp(i, 'RequestDay') || '');
            const counts = dashboardState.dailyStats.map(i => readNumber(i, 'TotalRequests'));
            document.querySelectorAll('.selected-module-title').forEach(el => el.textContent = dashboardState.selectedModule);
            updateDailyRequestsChart(labels, counts, dashboardState.moduleDailySeries, dashboardState.totalDailyStats);
            updateModuleDailyCharts(labels, dashboardState.selectedModule, dashboardState.moduleDailySeries);
            updateDurationChart(labels, dashboardState.dailyStats);
            renderTables(dashboardState.dailyStats, dashboardState.topServices);
            renderOperationalInsights();
        } finally {
            ['dailyRequestsCard', 'operationalSevenDaysCard', 'durationTrendCard', 'dailyDetailsCard'].forEach(id => setCardLoading(id, false));
        }
    };

    const updateStatusMetrics = async () => {
        setCardLoading('statusCodeCard', true);
        try {
            const response = await fetch(`${dashboardStatusUrl}?selectedModule=${encodeModule()}`);
            if (!response.ok) throw new Error('Dashboard status metrics request failed.');
            const data = await response.json();
            dashboardState.statusStats = readArray(data, 'StatusCodeStats');
            updateStatusChart(dashboardState.statusStats);
            renderOperationalInsights();
        } finally {
            setCardLoading('statusCodeCard', false);
        }
    };

    const updateTopServices = async () => {
        setCardLoading('topServicesCard', true);
        try {
            const response = await fetch(`${dashboardTopServicesUrl}?selectedModule=${encodeModule()}`);
            if (!response.ok) throw new Error('Dashboard top services request failed.');
            const data = await response.json();
            dashboardState.topServices = readArray(data, 'ModuleTopServices');
            renderTables(dashboardState.dailyStats, dashboardState.topServices);
        } finally {
            setCardLoading('topServicesCard', false);
        }
    };

    const updateMetrics = async () => {
        setMetricLoading();
        await Promise.allSettled([
            updateHourlyMetrics(),
            updateSevenDayMetrics(),
            updateStatusMetrics(),
            updateTopServices()
        ]);
    };

    const reloadDashboard = async () => {
        await Promise.allSettled([updateSummary(), updateMetrics()]);
    };

    document.addEventListener('DOMContentLoaded', () => {
        createCharts();
        reloadDashboard();
        const moduleSelect = document.getElementById('selectedModule');
        if (moduleSelect) {
            moduleSelect.addEventListener('change', () => {
                const url = new URL(window.location.href);
                url.searchParams.set('selectedModule', moduleSelect.value || 'All Modules');
                window.history.replaceState({}, '', url);
                reloadDashboard();
            });
        }
    });
</script>