@model QuickCode.Demo.Portal.Models.DashboardStatsViewModel
@functions {
    private static string ModuleOptionValue(string moduleName)
    {
        if (string.IsNullOrWhiteSpace(moduleName) ||
            string.Equals(moduleName.Trim(), "All Modules", StringComparison.OrdinalIgnoreCase))
            return "All Modules";

        var normalized = moduleName.Trim()
            .Replace("_", " ")
            .Replace("-", " ");
        normalized = string.Join(" ", normalized.Split(' ', StringSplitOptions.RemoveEmptyEntries));

        if (normalized.EndsWith(" Module", StringComparison.OrdinalIgnoreCase))
            normalized = normalized[..^7];
        else if (normalized.EndsWith("Module", StringComparison.OrdinalIgnoreCase))
            normalized = normalized[..^6];

        var key = normalized.Trim().ToLowerInvariant().Replace(" ", "-");
        return string.IsNullOrWhiteSpace(key) ? "All Modules" : $"{key}-module";
    }
}
<style>
    .dashboard-compact-table th,
    .dashboard-compact-table td {
        padding: 0.25rem 0.4rem;
        vertical-align: middle;
    }

    .dashboard-hero {
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
        border-radius: .35rem;
        background: #fff;
        border: 1px solid #e3e6f0;
        box-shadow: 0 .15rem 1.75rem 0 rgba(58, 59, 69, .15);
    }

    .dashboard-filter {
        min-width: 260px;
        height: calc(1.5em + .75rem + 2px);
        padding: .375rem 2.25rem .375rem .75rem;
        border-radius: .35rem;
        border-color: #d1d3e2;
        color: #6e707e;
        background-color: #fff;
        box-shadow: none;
        cursor: pointer;
        appearance: auto;
        -webkit-appearance: menulist;
    }

    .dashboard-filter:focus {
        border-color: #bac8f3;
        box-shadow: 0 0 0 .2rem rgba(78, 115, 223, .15);
    }

    .dashboard-filter-wrapper {
        position: relative;
    }

    .dashboard-filter-wrapper::after {
        content: "\f078";
        font-family: "Font Awesome 5 Free";
        font-weight: 900;
        position: absolute;
        right: .8rem;
        bottom: .56rem;
        color: #858796;
        font-size: .7rem;
        pointer-events: none;
    }

    .dashboard-card-loading {
        position: relative;
    }

    .dashboard-card-loading::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 5;
        border-radius: .35rem;
        background: rgba(255, 255, 255, .72);
        backdrop-filter: blur(1px);
    }

    .dashboard-card-loading::before {
        content: "Loading...";
        position: absolute;
        top: 50%;
        left: 50%;
        z-index: 6;
        transform: translate(-50%, -50%);
        padding-left: 1.6rem;
        font-size: .75rem;
        font-weight: 700;
        letter-spacing: .04em;
        text-transform: uppercase;
        color: #4e73df;
    }

    .dashboard-loading-spinner {
        position: absolute;
        top: 50%;
        left: calc(50% - 3.1rem);
        z-index: 7;
        width: 1rem;
        height: 1rem;
        margin-top: -.5rem;
        border: 2px solid rgba(78, 115, 223, .2);
        border-top-color: #4e73df;
        border-radius: 50%;
        animation: dashboardSpin .75s linear infinite;
        pointer-events: none;
    }

    .dashboard-table-scroll {
        max-height: 300px;
        overflow-y: auto;
        padding-bottom: 1px;
    }

    .dashboard-table-scroll thead th {
        position: sticky;
        top: 0;
        z-index: 1;
        background: #f8f9fc;
    }

    .dashboard-table-scroll .table-bordered tbody tr:last-child td {
        border-bottom: 1px solid #e3e6f0 !important;
    }

    .dashboard-top-services-scroll {
        max-height: 310px;
    }

    .dashboard-quick-link {
        text-decoration: none;
    }

    .dashboard-quick-link .card {
        transition: transform 0.12s ease, box-shadow 0.12s ease;
    }

    .dashboard-quick-link:hover .card {
        transform: translateY(-1px);
        box-shadow: 0 .25rem .75rem rgba(58, 59, 69, .18) !important;
    }

    .dashboard-skeleton {
        display: inline-block;
        min-width: 3rem;
        min-height: 1rem;
        border-radius: .35rem;
        color: transparent;
        background: linear-gradient(90deg, #edf2f7 25%, #f8fafc 37%, #edf2f7 63%);
        background-size: 400% 100%;
        animation: dashboardSkeleton 1.3s ease infinite;
    }

    @@keyframes dashboardSkeleton {
        0% { background-position: 100% 50%; }
        100% { background-position: 0 50%; }
    }

    @@keyframes dashboardSpin {
        to { transform: rotate(360deg); }
    }
</style>

<div class="container-fluid">
    <div class="dashboard-hero d-lg-flex align-items-center justify-content-between">
        <div class="mb-3 mb-lg-0">
            <h1 class="h3 mb-1 text-gray-900">Dashboard</h1>
            <div class="small text-muted">Live module health, traffic, latency, and access operations.</div>
        </div>
        <form method="get" action="@Url.Action("Index", "Home")" class="form-inline align-items-end">
            <div class="dashboard-filter-wrapper">
                <label for="selectedModule" class="text-xs font-weight-bold text-muted text-uppercase mb-1 d-block">Module Filter</label>
                <select id="selectedModule" name="selectedModule" class="custom-select dashboard-filter">
                @{
                    var selectedModuleValue = ModuleOptionValue(Model.SelectedModule);
                }
                @foreach (var module in Model.ModuleOptions)
                {
                    var optionValue = ModuleOptionValue(module);
                    if (string.Equals(optionValue, selectedModuleValue, StringComparison.OrdinalIgnoreCase))
                    {
                        <option selected="selected" value="@optionValue">@module</option>
                    }
                    else
                    {
                        <option value="@optionValue">@module</option>
                    }
                }
                </select>
            </div>
        </form>
    </div>

    <div class="row">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Modules</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800"><span id="totalModules" class="dashboard-skeleton">0</span></div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-layer-group fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Total Endpoints</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800"><span id="totalEndpoints" class="dashboard-skeleton">0</span></div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-link fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Permission Groups</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800"><span id="totalPermissionGroups" class="dashboard-skeleton">0</span></div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-user-shield fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Total Users</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800"><span id="totalUsers" class="dashboard-skeleton">0</span></div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-users fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.ManagementQuickLinks.Any())
    {
        <div class="row">
            @foreach (var link in Model.ManagementQuickLinks)
            {
                <div class="col-xl-3 col-md-6 mb-4">
                    <a class="dashboard-quick-link" href="@link.Url">
                        <div class="card border-left-secondary shadow h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-secondary text-uppercase mb-1">@link.Title</div>
                                        <div class="small mb-0 font-weight-bold text-gray-800">@link.Description</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="fas fa-fw @link.IconCss fa-2x text-gray-300"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }

    <div class="row align-items-stretch">
        <div class="col-xl-8 col-lg-7">
            <div id="hourlyRequestsCard" class="card shadow mb-4 dashboard-card-loading">
                <span class="dashboard-loading-spinner"></span>
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Module Requests (Last 24 Hours) - <span class="selected-module-title">@Model.SelectedModule</span></h6>
                </div>
                <div class="card-body">
                    <div class="chart-area" style="height: -webkit-fill-available;max-height: 400px;">
