                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-lg-5">
            <div id="operational24HoursCard" class="card shadow mb-4 dashboard-card-loading">
                <span class="dashboard-loading-spinner"></span>
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Last 24 Hours Operational Insights</h6>
                </div>
                <div class="card-body">
                    <div class="row">
