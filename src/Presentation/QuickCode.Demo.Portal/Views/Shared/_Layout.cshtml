    <script>
        // Initialize sidebar collapse after page load
        // Initialize sidebar collapse - Bootstrap 5 compatible
        $(document).ready(function() {
            // Wait for Bootstrap 5 to be loaded
            function initSidebarCollapse() {
                if (typeof bootstrap === 'undefined' || typeof $ === 'undefined') {
                    setTimeout(initSidebarCollapse, 100);
                    return;
                }
                
                // Bootstrap 5 collapse should work automatically with data-bs-toggle and data-bs-target
                // But we need to ensure proper event handling for accordion behavior
                
                // Update aria-expanded on collapse events
                $('#accordionSidebar .collapse').on('show.bs.collapse', function() {
                    var collapseId = '#' + $(this).attr('id');
                    var $trigger = $('[data-bs-target="' + collapseId + '"]');
                    if ($trigger.length) {
                        $trigger.attr('aria-expanded', 'true').removeClass('collapsed');
                    }
                });
                
                $('#accordionSidebar .collapse').on('hide.bs.collapse', function() {
                    var collapseId = '#' + $(this).attr('id');
                    var $trigger = $('[data-bs-target="' + collapseId + '"]');
                    if ($trigger.length) {
                        $trigger.attr('aria-expanded', 'false').addClass('collapsed');
                    }
                });
                
                // Ensure collapse triggers work - Bootstrap 5 should handle this automatically
                // but we add explicit click handler as fallback
                $('#accordionSidebar [data-bs-toggle="collapse"]').on('click', function(e) {
                    e.stopPropagation();
                    var target = $(this).attr('data-bs-target');
                    if (target && typeof bootstrap !== 'undefined') {
                        var $target = $(target);
                        var collapseInstance = bootstrap.Collapse.getInstance($target[0]);
                        if (!collapseInstance) {
                            collapseInstance = new bootstrap.Collapse($target[0], {
                                toggle: true,
                                parent: '#accordionSidebar'
                            });
                        } else {
                            collapseInstance.toggle();
                        }
                    }
                });
            }
            
            initSidebarCollapse();
        });
        
        // Close sidebar collapse menus when clicking outside - separate handler
        $(document).on('click', function(e) {
            // Check if click is outside sidebar and not on a sidebar toggle button
            var $target = $(e.target);
            var isSidebarClick = $target.closest('#accordionSidebar').length > 0;
            var isSidebarToggle = $target.closest('#sidebarToggleTop').length > 0;
            
            if (!isSidebarClick && !isSidebarToggle) {
                // Close all open collapses in sidebar
                $('#accordionSidebar .collapse.show').each(function() {
                    if (typeof bootstrap !== 'undefined') {
                        var collapseInstance = bootstrap.Collapse.getInstance(this);
                        if (collapseInstance) {
                            collapseInstance.hide();
                        }
                    } else {
                        $(this).collapse('hide');
                    }
                });
            }
        });

        function initPortalSidebarSearch() {
            var $input = $('#portalSidebarSearch');
            var $clear = $('#portalSidebarSearchClear');
            var $empty = $('#portalSidebarSearchEmpty');
            var searchStorageKey = 'portalSidebarSearchQuery';
            if (!$input.length) {
                return;
            }

            function normalizeSearchText(value) {
                return (value || '').toString().toLowerCase().trim();
            }

            function saveSidebarSearchQuery() {
                var raw = ($input.val() || '').toString().trim();
                try {
                    if (raw) {
                        localStorage.setItem(searchStorageKey, raw);
                    } else {
                        localStorage.removeItem(searchStorageKey);
                    }
                } catch (e) {
                    /* storage unavailable */
                }
            }

            function restoreSidebarSearchQuery() {
                try {
                    return localStorage.getItem(searchStorageKey) || '';
                } catch (e) {
                    return '';
                }
            }

            function matchesSearch(text, query) {
                return normalizeSearchText(text).indexOf(query) !== -1;
            }

            function getItemText($el) {
                var attr = $el.attr('data-nav-search');
                if (attr) {
                    return attr;
                }
                var label = $el.find('.portal-nav-label').first().text();
                return label || $el.text();
            }

            function updateSectionLabels($nav) {
                $nav.find('.portal-sidebar-section-label').each(function() {
                    var $label = $(this);
                    var hasVisible = false;
                    var $next = $label.next();
                    while ($next.length && !$next.hasClass('portal-sidebar-section-label')) {
                        if (!$next.hasClass('portal-nav-hidden')) {
                            hasVisible = true;
                            break;
                        }
                        $next = $next.next();
                    }
                    $label.toggleClass('portal-nav-hidden', !hasVisible);
                });
            }

            function expandSearchCollapse($collapse, $trigger) {
                if (!$collapse.length) {
                    return;
                }
                $collapse.removeClass('portal-nav-hidden collapsing').addClass('show').css('height', '');
                if ($trigger.length) {
                    $trigger.removeClass('collapsed portal-nav-hidden').attr('aria-expanded', 'true');
                }
            }

            function applySidebarSearch() {
                var query = normalizeSearchText($input.val());
                var $nav = $('#portalSidebarNav');

                saveSidebarSearchQuery();

                $nav.find('.portal-nav-hidden').removeClass('portal-nav-hidden');
                $empty.prop('hidden', true);

                if ($clear.length) {
                    $clear.prop('hidden', !query);
                }

                if (!query) {
                    return;
                }

                $nav.find('[data-nav-group="dashboard"]').each(function() {
                    var $item = $(this);
                    var text = getItemText($item.find('.portal-nav-link').first());
                    $item.toggleClass('portal-nav-hidden', !matchesSearch(text, query));
                });

                $nav.find('.portal-nav-subitem, .collapse-item').each(function() {
                    var $item = $(this);
                    var text = $item.attr('data-nav-search') || $item.text();
                    $item.toggleClass('portal-nav-hidden', !matchesSearch(text, query));
                });

                $nav.find('[data-bs-toggle="collapse"]').each(function() {
                    var $trigger = $(this);
                    var triggerText = getItemText($trigger);
                    var target = $trigger.attr('data-bs-target');
                    var $collapse = target ? $(target) : $();
                    var hasVisibleChild = $collapse.find('.portal-nav-subitem:not(.portal-nav-hidden), .collapse-item:not(.portal-nav-hidden)').length > 0;
                    var triggerMatch = matchesSearch(triggerText, query);
                    var visible = triggerMatch || hasVisibleChild;

                    $trigger.toggleClass('portal-nav-hidden', !visible);
                    $collapse.toggleClass('portal-nav-hidden', !visible);

                    if (visible && hasVisibleChild) {
                        expandSearchCollapse($collapse, $trigger);
                    }
                });

                $nav.find('.portal-nav-group').each(function() {
                    var $group = $(this);
                    var hasVisible = $group.find('.portal-nav-link:not(.portal-nav-hidden), .portal-nav-subitem:not(.portal-nav-hidden), .collapse-item:not(.portal-nav-hidden)').length > 0;
                    $group.toggleClass('portal-nav-hidden', !hasVisible);
                });

                updateSectionLabels($nav);

                var anyVisible = $nav.find('.nav-item:not(.portal-nav-hidden), .portal-nav-group:not(.portal-nav-hidden)').length > 0;
                $empty.prop('hidden', anyVisible);
            }

            function scheduleSidebarSearchRestore() {
                if (!normalizeSearchText($input.val())) {
                    return;
                }
                applySidebarSearch();
            }

            $input.on('input', applySidebarSearch);
            $input.on('keydown', function(e) {
                if (e.key === 'Escape') {
                    $input.val('');
                    applySidebarSearch();
                }
            });

            if ($clear.length) {
                $clear.on('click', function() {
                    $input.val('').trigger('focus');
                    applySidebarSearch();
                });
            }

            var savedQuery = restoreSidebarSearchQuery();
            if (savedQuery) {
                $input.val(savedQuery);
            }
            applySidebarSearch();
            $input.data('portalApplySearch', applySidebarSearch);

            setTimeout(scheduleSidebarSearchRestore, 0);
            setTimeout(scheduleSidebarSearchRestore, 100);
            setTimeout(scheduleSidebarSearchRestore, 300);
        }

        function initPortalSidebarMobile() {
            var $backdrop = $('#portalSidebarBackdrop');
            var $sidebar = $('#accordionSidebar');

            function isMobileViewport() {
                return window.innerWidth < 768;
            }

            function closeMobileSidebar() {
                if (!isMobileViewport()) {
                    return;
                }
                $('body').addClass('sidebar-toggled');
                $sidebar.addClass('toggled');
                updateMobileState();
            }

            function updateMobileState() {
                if (!isMobileViewport()) {
                    $('body').removeClass('portal-sidebar-mobile-open');
                    $backdrop.attr('aria-hidden', 'true');
                    return;
                }

                var isOpen = !$sidebar.hasClass('toggled');
                $('body').toggleClass('portal-sidebar-mobile-open', isOpen);
                $backdrop.attr('aria-hidden', isOpen ? 'false' : 'true');

                if (isOpen) {
                    var reapplySearch = $('#portalSidebarSearch').data('portalApplySearch');
                    if (typeof reapplySearch === 'function') {
                        reapplySearch();
                    }
                }
            }

            if ($sidebar.data('portalMobileInit')) {
                updateMobileState();
                return;
            }
            $sidebar.data('portalMobileInit', true);

            $backdrop.on('click', closeMobileSidebar);
            $('#portalSidebarClose').on('click', closeMobileSidebar);

            $(document).on('click', '#sidebarToggleTop', function() {
                setTimeout(updateMobileState, 80);
            });

            $(window).on('resize.portalSidebarMobile', function() {
                updateMobileState();
            });

            $sidebar.on('click', '.portal-nav-subitem, .portal-nav-link[href]:not([href="#"])', function() {
                if (isMobileViewport() && !$(this).is('[data-bs-toggle="collapse"]')) {
                    closeMobileSidebar();
                }
            });

            updateMobileState();
        }

        function initPortalSidebarResize() {
            var sidebar = document.getElementById('accordionSidebar');
            var resizer = document.getElementById('portalSidebarResizer');
            if (!sidebar || !resizer) {
                return;
            }

            var minWidth = 256;
            var maxWidth = 480;
            var storageKey = 'sidebarWidthPx';

            function applySidebarWidth(px) {
                var width = Math.round(Math.max(minWidth, Math.min(maxWidth, px)));
                document.documentElement.style.setProperty('--ps-width', width + 'px');
                localStorage.setItem(storageKey, String(width));
            }

            var savedWidth = parseInt(localStorage.getItem(storageKey), 10);
            if (!isNaN(savedWidth)) {
                applySidebarWidth(savedWidth);
            }

            var startX = 0;
            var startWidth = 0;
            var isDragging = false;

            function onPointerMove(clientX) {
                if (!isDragging) {
                    return;
                }
                applySidebarWidth(startWidth + (clientX - startX));
            }

            function stopResize() {
                if (!isDragging) {
                    return;
                }
                isDragging = false;
                sidebar.classList.remove('is-resizing');
                document.body.style.cursor = '';
                document.body.style.userSelect = '';
                document.removeEventListener('mousemove', onMouseMove);
                document.removeEventListener('mouseup', stopResize);
            }

            function onMouseMove(e) {
                onPointerMove(e.clientX);
            }

            resizer.addEventListener('mousedown', function(e) {
                if (sidebar.classList.contains('toggled') || window.innerWidth < 768) {
                    return;
                }
                e.preventDefault();
                isDragging = true;
                startX = e.clientX;
                startWidth = sidebar.getBoundingClientRect().width;
                sidebar.classList.add('is-resizing');
                document.body.style.cursor = 'col-resize';
                document.body.style.userSelect = 'none';
                document.addEventListener('mousemove', onMouseMove);
                document.addEventListener('mouseup', stopResize);
            });
        }

        function initPortalBreadcrumbDropdowns() {
            if (typeof bootstrap === 'undefined' || !bootstrap.Dropdown) {
                return;
            }

            document.querySelectorAll('.portal-bc-trigger[data-bs-toggle="dropdown"], .portal-user-menu-toggle[data-bs-toggle="dropdown"]').forEach(function(el) {
                bootstrap.Dropdown.getOrCreateInstance(el);
            });
        }
        
        function isPortalMobileViewport() {
            return window.innerWidth < 768;
        }

        function closeMobileSidebarDrawer() {
            if (!isPortalMobileViewport()) {
                return;
            }
            $('body').addClass('sidebar-toggled');
            $('#accordionSidebar').addClass('toggled');
        }

        function syncPortalNavParentActive() {
            var $nav = $('#portalSidebarNav');
            $nav.find('.nav-link.portal-nav-parent-active').removeClass('portal-nav-parent-active');

            $nav.find('.portal-nav-subitem.active, .collapse-item.active').each(function() {
                var $collapse = $(this).closest('.collapse');
                var collapseId = $collapse.attr('id');
                if (!collapseId) {
                    return;
                }
                $nav.find('[data-bs-target="#' + collapseId + '"]').addClass('portal-nav-parent-active');
            });
        }

        function syncPortalNavRailIndicator(options) {
            var nav = document.getElementById('portalSidebarNav');
            var indicator = document.getElementById('portalNavRailIndicator');
            if (!nav || !indicator) {
                return;
            }

            var active =
                nav.querySelector('.portal-nav-subitem.active, .collapse-item.active') ||
                nav.querySelector('.nav-item.portal-nav-current > .nav-link');

            if (!active || active.classList.contains('portal-nav-hidden') || active.offsetParent === null) {
                indicator.classList.remove('is-visible');
                return;
            }

            var navRect = nav.getBoundingClientRect();
            var activeRect = active.getBoundingClientRect();
            var top = activeRect.top - navRect.top + nav.scrollTop;
            var height = Math.max(16, Math.min(24, activeRect.height * 0.58));
            var y = top + (activeRect.height - height) / 2;

            // Prefer the existing submenu tree rail (near the item text).
            var collapseInner = active.closest('.collapse-inner, .portal-collapse-inner');
            var x;

            if (collapseInner) {
                var probe = document.createElement('span');
                probe.setAttribute('aria-hidden', 'true');
                probe.style.cssText = 'position:absolute;left:var(--ps-tree-rail-x);top:0;width:1px;height:1px;visibility:hidden;pointer-events:none;';
                collapseInner.appendChild(probe);
                var probeRect = probe.getBoundingClientRect();
                x = probeRect.left - navRect.left - 1;
                probe.remove();
            } else {
                x = activeRect.left - navRect.left + 2;
            }

            indicator.style.height = height + 'px';
            indicator.style.transform = 'translate3d(' + Math.max(0, x) + 'px, ' + Math.max(0, y) + 'px, 0)';
            indicator.classList.add('is-visible');
        }

        function initPortalNavRail() {
            var nav = document.getElementById('portalSidebarNav');
            if (!nav) {
                return;
            }

            var schedule = function() {
                window.requestAnimationFrame(function() {
                    syncPortalNavRailIndicator();
                });
            };

            schedule();

            nav.addEventListener('scroll', schedule, { passive: true });
            $(window).on('resize.portalNavRail', schedule);
            $('#accordionSidebar').on('shown.bs.collapse hidden.bs.collapse', schedule);

            var observer = new MutationObserver(schedule);
            observer.observe(nav, { childList: true, subtree: true, attributes: true, attributeFilter: ['class', 'hidden', 'aria-current'] });
        }

        function forceDesktopSidebarExpanded() {
            if (isPortalMobileViewport()) {
                return;
            }
            $('#accordionSidebar').removeClass('toggled');
            $('body').removeClass('sidebar-toggled');
        }

        $(document).ready(function() {
            initPortalBreadcrumbDropdowns();
            initPortalSidebarSearch();
            initPortalSidebarResize();
            initPortalSidebarMobile();
            syncPortalNavParentActive();
            initPortalNavRail();

            forceDesktopSidebarExpanded();

            function closeSidebarCollapsesIfDrawerClosed() {
                if (!isPortalMobileViewport()) {
                    return;
                }
                var isDrawerClosed = $('#accordionSidebar').hasClass('toggled') || $('body').hasClass('sidebar-toggled');
                if (!isDrawerClosed) {
                    return;
                }

                $('#accordionSidebar .collapse').each(function() {
                    var $collapse = $(this);
                    var collapseId = '#' + $collapse.attr('id');
                    var $trigger = $('#accordionSidebar [data-bs-target="' + collapseId + '"]');

                    $collapse.removeClass('show');
                    if ($trigger.length) {
                        $trigger.addClass('collapsed').attr('aria-expanded', 'false');
                    }

                    if (typeof bootstrap !== 'undefined' && bootstrap.Collapse) {
                        var instance = bootstrap.Collapse.getInstance($collapse[0]);
                        if (instance) {
                            instance.hide();
                        }
                    }
                });
            }

            var isMobile = isPortalMobileViewport();

            if (isMobile) {
                closeMobileSidebarDrawer();
                closeSidebarCollapsesIfDrawerClosed();
                initPortalSidebarMobile();
                // sb-admin-2 also runs on ready; re-assert closed state once more
                setTimeout(function() {
                    closeMobileSidebarDrawer();
                    closeSidebarCollapsesIfDrawerClosed();
                    initPortalSidebarMobile();
                }, 50);
            } else {
                forceDesktopSidebarExpanded();
            }

            setTimeout(forceDesktopSidebarExpanded, 200);

            setTimeout(function() {
                var reapplySearch = $('#portalSidebarSearch').data('portalApplySearch');
                if (typeof reapplySearch === 'function') {
                    reapplySearch();
                }
            }, 350);

             // Update wrapper classes based on checkbox state
        $('.ios-switch').each(function() {
            var $wrapper = $(this).closest('.ios-switch-wrapper');
            if ($(this).is(':checked')) {
                $wrapper.addClass('checked');
            } else {
                $wrapper.removeClass('checked');
            }
        });
        
        // Update on change
        $(document).on('change', '.ios-switch', function() {
            var $wrapper = $(this).closest('.ios-switch-wrapper');
            if ($(this).is(':checked')) {
                $wrapper.addClass('checked');
            } else {
                $wrapper.removeClass('checked');
            }
        });
        
        // Allow clicking on wrapper to toggle switch - iOS compatible with touch events
        var touchStartTime = 0;
        var touchStartTarget = null;
        
        $(document).on('touchstart', '.ios-switch-wrapper', function(e) {
            touchStartTime = Date.now();
            touchStartTarget = $(this);
            e.preventDefault();
        });
        
        $(document).on('touchend', '.ios-switch-wrapper', function(e) {
            var touchEndTime = Date.now();
            var touchDuration = touchEndTime - touchStartTime;
            var $target = $(this);
            
            // Only trigger if it's a quick tap (not a swipe) and same target
            if (touchDuration < 300 && touchStartTarget && touchStartTarget[0] === $target[0]) {
                if (!$(e.target).is('.ios-switch')) {
                    var $switch = $target.find('.ios-switch');
                    // Don't toggle if switch is disabled
                    if ($switch.is(':disabled')) {
                        touchStartTarget = null;
                        return false;
                    }
                    $switch.prop('checked', !$switch.prop('checked')).trigger('change');
                }
            }
            touchStartTarget = null;
            e.preventDefault();
        });
        
        $(document).on('click', '.ios-switch-wrapper', function(e) {
            // For non-touch devices, keep click handler
            if (!('ontouchstart' in window)) {
                if (!$(e.target).is('.ios-switch')) {
                    var $switch = $(this).find('.ios-switch');
                    // Don't toggle if switch is disabled
                    if ($switch.is(':disabled')) {
                        return false;
                    }
                    $switch.prop('checked', !$switch.prop('checked')).trigger('change');
                }
            }
        });
            
            $(window).on('resize', function() {
                var newIsMobile = isPortalMobileViewport();
                if (newIsMobile !== isMobile) {
                    isMobile = newIsMobile;
                    if (!isMobile) {
                        forceDesktopSidebarExpanded();
                    } else {
                        closeMobileSidebarDrawer();
                        closeSidebarCollapsesIfDrawerClosed();
                        initPortalSidebarMobile();
                    }
                }
            });
        });
    </script>
