    <style>
        /* Content area padding - defined early to prevent flash */
        .content-area {
            padding-top: 12px;
        }
        .portal-topbar {
            display: flex;
            align-items: center;
            min-height: 0;
            height: auto;
            padding: 0.5rem 1.25rem;
            margin-bottom: 0.75rem;
            background: #fff;
            border-bottom: 1px solid #e3e6f0;
            overflow: visible;
            position: relative;
            z-index: 20;
        }
        .portal-breadcrumb {
            overflow: visible;
        }
        .content-area.portal-is-dashboard .portal-breadcrumb {
            display: none !important;
        }
        @@media (min-width: 768px) {
            .portal-topbar-mobile-only {
                display: none;
            }
            .content-area.portal-is-dashboard {
                padding-top: 12px;
            }
        }
        .portal-bc-list {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.35rem;
            list-style: none;
            margin: 0;
            padding: 0;
        }
        .portal-bc-item {
            display: inline-flex;
            align-items: center;
        }
        .portal-bc-separator {
            display: inline-flex;
            align-items: center;
            color: #d1d3e2;
            font-size: 0.6rem;
            line-height: 1;
        }
        .portal-bc-link,
        .portal-bc-text {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            color: #4e73df;
            font-size: 0.875rem;
            font-weight: 500;
            text-decoration: none;
            line-height: 1.4;
        }
        .portal-bc-link:hover {
            color: #2e59d9;
            text-decoration: none;
        }
        .portal-bc-home-icon {
            font-size: 0.8rem;
            opacity: 0.85;
        }
        .portal-bc-current {
            display: inline-flex;
            align-items: center;
            padding: 0.2rem 0.65rem;
            border-radius: 999px;
            background: #eef2ff;
            color: #3b488e;
            font-size: 0.875rem;
            font-weight: 600;
            line-height: 1.4;
        }
        .portal-bc-switcher {
            display: inline-flex;
            position: relative;
        }
        .portal-bc-trigger {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            border: 1px solid #d1d3e2;
            border-radius: 999px;
            padding: 0.2rem 0.75rem;
            background: #fff;
            color: #5a5c69;
            font-size: 0.875rem;
            font-weight: 500;
            line-height: 1.4;
            cursor: pointer;
        }
        .portal-bc-trigger:hover,
        .portal-bc-trigger:focus,
        .portal-bc-trigger.show {
            background: #f8f9fc;
            color: #4e73df;
            border-color: #bac8f3;
            outline: none;
            box-shadow: none;
        }
        .portal-bc-trigger::after {
            margin-left: 0.15rem;
            vertical-align: middle;
        }
        .portal-bc-menu {
            min-width: 12rem;
            max-height: 18rem;
            overflow-y: auto;
            border-color: #e3e6f0;
            font-size: 0.875rem;
            z-index: 1100;
        }
        .portal-bc-menu .dropdown-item.active {
            background: #eef2ff;
            color: #3b488e;
            font-weight: 600;
        }
        /* Page headers: breadcrumb already shows location — keep titles compact */
        .content-area .card-body > h1.card-title,
        .content-area .card-body > h2.card-title {
            font-size: 1.5rem;
            font-weight: 600;
            color: #5a5c69;
            margin-bottom: 0.35rem;
            line-height: 1.35;
        }
        .content-area .card-body > p.card-text {
            font-size: 0.875rem;
            color: #858796;
            margin-bottom: 0.85rem;
            line-height: 1.5;
        }
        .content-area .card-body > hr {
            margin-top: 0.25rem;
            margin-bottom: 1rem;
        }
        /* Active nav styles live in portal-sidebar.css */
        /* Mobile responsive - remove top padding on mobile */
        @@media (max-width: 767.98px) {
            .content-area {
                padding-top: 0 !important;
            }
        }
    </style>
    @inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
    @{
        var antiforgeryTokens = Antiforgery.GetAndStoreTokens(Context);
    }
    <meta name="request-verification-token" content="@antiforgeryTokens.RequestToken" />
</head>
<body id="page-top">
    <partial name="_CookieConsentPartial" />
    <!-- Page Wrapper -->
    <div id="wrapper">
        <!-- Sidebar -->
        <div class="portal-sidebar-backdrop" id="portalSidebarBackdrop" aria-hidden="true"></div>
        <nav class="navbar-nav portal-sidebar sidebar sidebar-dark bg-gradient-primary accordion" id="accordionSidebar" aria-label="Main navigation">
            <div class="portal-sidebar-visual" aria-hidden="true">
                <img class="portal-sidebar-visual__media"
                     src="/images/sidebar-visual.svg?v=9"
                     alt=""
                     decoding="async" />
                <div class="portal-sidebar-visual__veil"></div>
            </div>

            <div class="portal-sidebar-header">
                <div class="portal-sidebar-header-row">
                    <a class="portal-sidebar-brand" href="/">
                        <div class="portal-brand-logo-wrap">
                            <img class="portal-brand-logo" src="/images/logo_s1.png" alt="QuickCode" />
                        </div>
                    </a>
                    <button type="button" class="portal-sidebar-close d-md-none" id="portalSidebarClose" aria-label="Close menu">
                        <i class="fas fa-times" aria-hidden="true"></i>
                    </button>
                </div>
            </div>

            <div class="portal-sidebar-user">
                <div class="portal-user-panel">
                    <div class="portal-user-card-row">
                        @await Component.InvokeAsync(nameof(UserOperation))
                        <div class="dropdown portal-user-menu">
                            <button type="button"
                                    class="portal-user-menu-toggle"
                                    id="portalUserMenuToggle"
                                    data-bs-toggle="dropdown"
                                    data-bs-auto-close="true"
                                    data-bs-popper-config='{"strategy":"fixed"}'
                                    aria-expanded="false"
                                    aria-label="Account menu"
                                    title="Account">
                                <i class="fas fa-ellipsis-v" aria-hidden="true"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end portal-user-dropdown" aria-labelledby="portalUserMenuToggle">
                                <li>
                                    <button type="button"
                                            class="dropdown-item portal-user-dropdown-item portal-user-dropdown-logout"
                                            data-bs-toggle="modal"
                                            data-bs-target="#logoutModal">
                                        <i class="fas fa-sign-out-alt" aria-hidden="true"></i>
                                        <span>Logout</span>
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </div>
                    <div class="portal-user-project-row">
                        <i class="fas fa-project-diagram portal-user-project-icon" aria-hidden="true"></i>
                        <span class="portal-user-project">Demo</span>
                    </div>
                </div>
            </div>

            <div class="portal-sidebar-search-wrap">
                <label class="portal-sidebar-search mb-0 w-100" for="portalSidebarSearch">
                    <i class="fas fa-search portal-sidebar-search-icon" aria-hidden="true"></i>
                    <input type="search"
                           id="portalSidebarSearch"
                           class="portal-sidebar-search-input"
                           placeholder="Search menus..."
                           autocomplete="off"
                           aria-label="Search navigation" />
                    <button type="button" class="portal-sidebar-search-clear" id="portalSidebarSearchClear" aria-label="Clear search" hidden>
                        <i class="fas fa-times" aria-hidden="true"></i>
                    </button>
                </label>
            </div>

            <div class="portal-sidebar-body" id="portalSidebarNav">
            <div class="portal-nav-rail" aria-hidden="true">
                <div class="portal-nav-rail__indicator" id="portalNavRailIndicator">
                    <span class="portal-nav-rail__bar"></span>
                </div>
            </div>
            @{
                var isDashboard = PortalNavigationHelper.IsDashboardPage(Context);
            }
            <div class="nav-item@(isDashboard ? " portal-nav-current" : "")" data-nav-group="dashboard">
                <a class="nav-link portal-nav-link@(isDashboard ? " portal-nav-current-link" : "")" href="/" data-nav-search="dashboard"@(isDashboard ? Html.Raw(" aria-current=\"page\"") : null)>
                    <span class="nav-link-main">
                        <i class="fas fa-fw fa-tachometer-alt portal-nav-icon"></i>
                        <span class="portal-nav-label">Dashboard</span>
                    </span>
                </a>
            </div>

            <p class="portal-sidebar-section-label portal-sidebar-section-divider portal-sidebar-section--management">
                <span class="portal-sidebar-section-main">
                    <i class="fas fa-fw fa-sliders-h portal-sidebar-section-icon" aria-hidden="true"></i>
                    <span>Management</span>
                </span>
            </p>
            <sidebar-item title="Access Grant Managers" key="AccessGrantManagers"></sidebar-item>
            <sidebar-item title="Workflow Managers" key="WorkflowManagers"></sidebar-item>
            <sidebar-item title="Portal Settings" key="PortalSettings"></sidebar-item>
            <sidebar-item title="Permission Settings" key="PermissionSettings"></sidebar-item>
            <sidebar-item title="Audit Logs" key="AuditLogs"></sidebar-item>

            <p class="portal-sidebar-section-label portal-sidebar-section-divider portal-sidebar-section--modules">
                <span class="portal-sidebar-section-main">
                    <i class="fas fa-fw fa-cubes portal-sidebar-section-icon" aria-hidden="true"></i>
                    <span>Modules</span>
                </span>
            </p>
            <sidebar-item title="Tables" key="Tables"></sidebar-item>
            </div>

            <div class="portal-sidebar-search-empty" id="portalSidebarSearchEmpty" hidden>
                <i class="fas fa-search" aria-hidden="true"></i>
                <span>No matching menu items</span>
            </div>

            <div class="portal-sidebar-footer" aria-hidden="true"></div>

            <div class="portal-sidebar-resizer" id="portalSidebarResizer" role="separator" aria-orientation="vertical" aria-label="Resize sidebar" title="Drag to resize sidebar"></div>

        </nav>
        <!-- End of Sidebar -->



        <div id="content-wrapper" class="d-flex flex-column">
            <!-- Main Content -->
            @{
                var isDashboardPage = PortalNavigationHelper.IsDashboardPage(Context);
            }
            <div id="content" class="content-area@(isDashboardPage ? " portal-is-dashboard" : "")">
                <div class="portal-topbar@(isDashboardPage ? " portal-topbar-mobile-only" : "")">
                    <button id="sidebarToggleTop" class="btn btn-link rounded-circle mr-2 d-md-none p-1" type="button">
                        <i class="fa fa-bars"></i>
                    </button>
                    @if (!isDashboardPage)
                    {
                        @await Component.InvokeAsync("PortalBreadcrumb")
                    }
                </div>
                @RenderBody()

            </div>


            <!-- Footer -->
            <footer class="sticky-footer portal-sticky-footer bg-white">
                <div class="copyright text-center">
                    <span>Copyright &copy; QuickCode @Html.Raw(DateTime.Now.Year.ToString()). All rights reserved.</span>
                </div>
            </footer>
            <!-- End of Footer -->
        </div>
    </div>
    <!-- Scroll to Top Button-->
    <a class="scroll-to-top rounded" href="#page-top">
        <i class="fas fa-angle-up"></i>
    </a>
    <!-- Logout Modal-->
    <div class="modal fade" id="logoutModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
