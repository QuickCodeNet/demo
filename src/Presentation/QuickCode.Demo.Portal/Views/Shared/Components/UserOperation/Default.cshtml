@model UserDetail
<div class="portal-user-top">
    @if (!string.IsNullOrEmpty(Model.ImageUrl) && Model.ImageUrl != "/images/no_image.png")
    {
        <img class="portal-user-avatar" src="@Model.ImageUrl" alt="@(Model.NameSurname ?? "User")" />
    }
    else
    {
        <div class="portal-user-avatar-fallback" aria-hidden="true">
            <i class="fas fa-user"></i>
        </div>
    }
    <div class="portal-user-meta">
        <div class="portal-user-name">@(Model.NameSurname ?? "User")</div>
        <div class="portal-user-role">@(Model.GroupName ?? "User")</div>
    </div>
</div>
