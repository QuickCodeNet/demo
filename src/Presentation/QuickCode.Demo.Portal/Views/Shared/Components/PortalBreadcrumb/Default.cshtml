@using QuickCode.Demo.Portal.Helpers
@model IReadOnlyList<QuickCode.Demo.Portal.Models.PortalBreadcrumbItem>
@{
    var items = Model ?? Array.Empty<QuickCode.Demo.Portal.Models.PortalBreadcrumbItem>();
    var hideBreadcrumb = PortalNavigationHelper.IsDashboardPage(Context);
}
@if (!hideBreadcrumb && items.Count > 0)
{
    <nav aria-label="breadcrumb" class="portal-breadcrumb flex-grow-1">
        <ol class="portal-bc-list">
            @for (var i = 0; i < items.Count; i++)
            {
                var item = items[i];
                if (i > 0)
                {
                    <li class="portal-bc-separator" aria-hidden="true">
                        <i class="fas fa-chevron-right"></i>
                    </li>
                }

                <li class="portal-bc-item@(item.IsActive ? " is-current" : "")">
                    @if (item.IsActive)
                    {
                        <span class="portal-bc-current">@item.Text</span>
                    }
                    else if (item.RelatedLinks.Count > 1)
                    {
                        var switcherId = $"portal-bc-switcher-{i}";
                        <div class="dropdown portal-bc-switcher">
                            <button type="button"
                                    class="portal-bc-trigger dropdown-toggle"
                                    id="@switcherId"
                                    data-bs-toggle="dropdown"
                                    data-bs-auto-close="true"
                                    aria-expanded="false">
                                @item.Text
                            </button>
                            <ul class="dropdown-menu portal-bc-menu shadow-sm" aria-labelledby="@switcherId">
                                @if (!string.IsNullOrWhiteSpace(item.Url))
                                {
                                    <li>
                                        <a class="dropdown-item" href="@item.Url">@item.Text overview</a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                }
                                @foreach (var link in item.RelatedLinks)
                                {
                                    <li>
                                        @if (link.IsActive)
                                        {
                                            <span class="dropdown-item active">@link.Text</span>
                                        }
                                        else
                                        {
                                            <a class="dropdown-item" href="@link.Url">@link.Text</a>
                                        }
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(item.Url))
                    {
                        @if (i == 0)
                        {
                            <a class="portal-bc-link" href="@item.Url">
                                <i class="fas fa-tachometer-alt portal-bc-home-icon" aria-hidden="true"></i>
                                <span>@item.Text</span>
                            </a>
                        }
                        else
                        {
                            <a class="portal-bc-link" href="@item.Url">@item.Text</a>
                        }
                    }
                    else
                    {
                        <span class="portal-bc-text">@item.Text</span>
                    }
                </li>
            }
        </ol>
    </nav>
}
