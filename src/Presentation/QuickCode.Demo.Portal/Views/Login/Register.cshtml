@model RegisterData
@{
    ViewData["Title"] = "Create account";
    var queryCollection = Context.Request.Query;
    var routeData = new Dictionary<string, string>(queryCollection.Select(x => new KeyValuePair<string, string>(x.Key, x.Value!)));
}

<section class="auth-card">
    <div class="auth-card__inner">
        <p class="auth-card__eyebrow">Get started</p>
        <h1 class="auth-card__title">Create your account</h1>
        <p class="auth-card__lead">Set up access in a few steps. You can sign in right after registration.</p>

        <form class="auth-form" asp-action="Register" asp-all-route-data="routeData" novalidate>
            <div class="auth-name-grid">
                <div class="auth-field">
                    <label class="auth-field__label" asp-for="FirstName">First name</label>
                    <input asp-for="FirstName"
                           class="auth-field__input"
                           autocomplete="given-name"
                           placeholder="First name"
                           aria-required="true" />
                    <span asp-validation-for="FirstName" class="auth-field__hint"></span>
                </div>
                <div class="auth-field">
                    <label class="auth-field__label" asp-for="LastName">Last name</label>
                    <input asp-for="LastName"
                           class="auth-field__input"
                           autocomplete="family-name"
                           placeholder="Last name"
                           aria-required="true" />
                    <span asp-validation-for="LastName" class="auth-field__hint"></span>
                </div>
            </div>

            <div class="auth-field">
                <label class="auth-field__label" asp-for="Email">Email</label>
                <input asp-for="Email"
                       class="auth-field__input"
                       type="email"
                       autocomplete="email"
                       inputmode="email"
                       placeholder="name@company.com"
                       aria-required="true" />
                <span asp-validation-for="Email" class="auth-field__hint"></span>
            </div>

            <div class="auth-field">
                <label class="auth-field__label" asp-for="Password">Password</label>
                <div class="auth-password">
                    <input asp-for="Password"
                           id="register-password"
                           class="auth-field__input"
                           type="password"
                           autocomplete="new-password"
                           placeholder="At least 6 characters"
                           aria-required="true" />
                    <button type="button"
                            class="auth-password__toggle"
                            data-auth-password-toggle
                            aria-controls="register-password"
                            aria-pressed="false"
                            aria-label="Show password">
                        <i class="far fa-eye" aria-hidden="true"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="auth-field__hint"></span>
            </div>

            <div class="auth-field">
                <label class="auth-field__label" asp-for="ConfirmPassword">Confirm password</label>
                <div class="auth-password">
                    <input asp-for="ConfirmPassword"
                           id="register-confirm-password"
                           class="auth-field__input"
                           type="password"
                           autocomplete="new-password"
                           placeholder="Re-enter password"
                           aria-required="true" />
                    <button type="button"
                            class="auth-password__toggle"
                            data-auth-password-toggle
                            aria-controls="register-confirm-password"
                            aria-pressed="false"
                            aria-label="Show password">
                        <i class="far fa-eye" aria-hidden="true"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="auth-field__hint"></span>
            </div>

            <button type="submit" class="auth-btn">Create account</button>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="auth-alert auth-alert--error" role="alert">@Model.ErrorMessage</div>
            }
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="auth-alert auth-alert--success" role="status">@Model.SuccessMessage</div>
            }
        </form>

        <div class="auth-footer">
            <span>Already have an account? <a class="auth-link" asp-action="Index" asp-controller="Login">Sign in</a></span>
            <a class="auth-link" asp-action="ForgotPassword" asp-controller="Login">Forgot password?</a>
        </div>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
