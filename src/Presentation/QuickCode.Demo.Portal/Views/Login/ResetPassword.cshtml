@model ResetPasswordData
@{
    ViewData["Title"] = "Reset password";
    var queryCollection = Context.Request.Query;
    var routeData = new Dictionary<string, string>(queryCollection.Select(x => new KeyValuePair<string, string>(x.Key, x.Value!)));
}

<section class="auth-card">
    <div class="auth-card__inner">
        <p class="auth-card__eyebrow">Account recovery</p>
        <h1 class="auth-card__title">Choose a new password</h1>
        <p class="auth-card__lead">Use the reset code from your email, then set a password you’ll remember.</p>

        <form class="auth-form" asp-action="ResetPassword" asp-all-route-data="routeData" novalidate>
            <div class="auth-field">
                <label class="auth-field__label" asp-for="Email">Email</label>
                <input asp-for="Email"
                       class="auth-field__input"
                       type="email"
                       autocomplete="email"
                       inputmode="email"
                       placeholder="name@company.com"
                       aria-required="true" />
                <span asp-validation-for="Email" class="auth-field__hint"></span>
            </div>

            <div class="auth-field">
                <label class="auth-field__label" asp-for="ResetCode">Reset code</label>
                <input asp-for="ResetCode"
                       class="auth-field__input"
                       autocomplete="one-time-code"
                       inputmode="text"
                       placeholder="Enter the code"
                       aria-required="true" />
                <span asp-validation-for="ResetCode" class="auth-field__hint"></span>
            </div>

            <div class="auth-field">
                <label class="auth-field__label" asp-for="NewPassword">New password</label>
                <div class="auth-password">
                    <input asp-for="NewPassword"
                           id="reset-password"
                           class="auth-field__input"
                           type="password"
                           autocomplete="new-password"
                           placeholder="At least 6 characters"
                           aria-required="true" />
                    <button type="button"
                            class="auth-password__toggle"
                            data-auth-password-toggle
                            aria-controls="reset-password"
                            aria-pressed="false"
                            aria-label="Show password">
                        <i class="far fa-eye" aria-hidden="true"></i>
                    </button>
                </div>
                <span asp-validation-for="NewPassword" class="auth-field__hint"></span>
            </div>

            <div class="auth-field">
                <label class="auth-field__label" asp-for="ConfirmPassword">Confirm password</label>
                <div class="auth-password">
                    <input asp-for="ConfirmPassword"
                           id="reset-confirm-password"
                           class="auth-field__input"
                           type="password"
                           autocomplete="new-password"
                           placeholder="Re-enter password"
                           aria-required="true" />
                    <button type="button"
                            class="auth-password__toggle"
                            data-auth-password-toggle
                            aria-controls="reset-confirm-password"
                            aria-pressed="false"
                            aria-label="Show password">
                        <i class="far fa-eye" aria-hidden="true"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="auth-field__hint"></span>
            </div>

            <button type="submit" class="auth-btn">Update password</button>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="auth-alert auth-alert--error" role="alert">@Model.ErrorMessage</div>
            }
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="auth-alert auth-alert--success" role="status">@Model.SuccessMessage</div>
            }
        </form>

        <div class="auth-footer">
            <a class="auth-link" asp-action="Index" asp-controller="Login">Back to sign in</a>
            <a class="auth-link" asp-action="ForgotPassword" asp-controller="Login">Request a new code</a>
        </div>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
