@model ForgotPasswordData
@{
    ViewData["Title"] = "Forgot password";
    var queryCollection = Context.Request.Query;
    var routeData = new Dictionary<string, string>(queryCollection.Select(x => new KeyValuePair<string, string>(x.Key, x.Value!)));
}

<section class="auth-card">
    <div class="auth-card__inner">
        <p class="auth-card__eyebrow">Account recovery</p>
        <h1 class="auth-card__title">Reset your password</h1>
        <p class="auth-card__lead">Enter the email on your account. We’ll send a reset code if it matches.</p>

        <form class="auth-form" asp-action="ForgotPassword" asp-all-route-data="routeData" novalidate>
            <div class="auth-field">
                <label class="auth-field__label" asp-for="Email">Email</label>
                <input asp-for="Email"
                       class="auth-field__input"
                       type="email"
                       autocomplete="email"
                       inputmode="email"
                       placeholder="name@company.com"
                       aria-required="true" />
                <span asp-validation-for="Email" class="auth-field__hint"></span>
            </div>

            <button type="submit" class="auth-btn">Send reset code</button>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="auth-alert auth-alert--error" role="alert">@Model.ErrorMessage</div>
            }
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="auth-alert auth-alert--success" role="status">@Model.SuccessMessage</div>
            }
        </form>

        <div class="auth-footer">
            <span>Remembered it? <a class="auth-link" asp-action="Index" asp-controller="Login">Back to sign in</a></span>
            <a class="auth-link" asp-action="Register" asp-controller="Login">Create an account</a>
        </div>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
