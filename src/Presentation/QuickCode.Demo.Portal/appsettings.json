{
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  },
  "RateLimiting": {
    "Enabled": true,
    "ApplyAuthPolicies": true,
    "General": {
      "PermitLimit": 1000,
      "WindowSeconds": 60
    },
    "Auth": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    },
    "Refresh": {
      "PermitLimit": 60,
      "WindowSeconds": 60
    }
  },
  "AllowedHosts": "*"
}
