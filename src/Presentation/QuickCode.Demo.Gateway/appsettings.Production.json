{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    },
    "ApiName": "quickcode-demo-gateway",
    "ElasticConfiguration": {
      "Uri": ""
    }
  },
  "QuickcodeClients": {
    "GatewayApi": "https://demo-gateway-821209474183.europe-west1.run.app/",
    "IdentityModuleApi": "https://demo-identity-module-821209474183.europe-west1.run.app/",
    "FinanceSettlementModuleApi": "https://demo-finance-settlement-module-821209474183.europe-west1.run.app/",
    "OrderManagementModuleApi": "https://demo-order-management-module-821209474183.europe-west1.run.app/",
    "PricingEngineModuleApi": "https://demo-pricing-engine-module-821209474183.europe-west1.run.app/",
    "ProductCatalogModuleApi": "https://demo-product-catalog-module-821209474183.europe-west1.run.app/",
    "SellerManagementModuleApi": "https://demo-seller-management-module-821209474183.europe-west1.run.app/"
  },
  "GatewayServiceTokenSettings": {
    "Issuer": "quickcode-gateway",
    "ExpirationSeconds": 60
  },
  "Kafka": {
	"BootstrapServers": "kafka.quickcode.net:9092",
	"GroupId": "WorkflowGroup"
  },
  "CorsSettings": {
    "AllowOrigins": [ "https://*.quickcode.net", "https://*.europe-west1.run.app" ]
  },
  "AppSettings": {
    "PortalUrl": "https://demo-portal-821209474183.europe-west1.run.app",
    "ElasticUrl": "http://kibana.quickcode.net:5601/app/discover/",
    "KafdropUrl": "https://kafdrop.quickcode.net",
    "EventListenerUrl": "https://demo-event-listener-service-821209474183.europe-west1.run.app",
    "DatabaseType": "mssql",
    "InMemoryDbName": "EventListenerDb",
    "UseHealthCheck": "true",
    "HealthCheckSeconds": "3600"
  },
  "HealthChecksUI": {
    "HealthChecks": [
      {
        "Name": "gateway-api health checks",
        "Uri": "https://demo-gateway-821209474183.europe-west1.run.app/hc"
      },
      {
        "Name": "event-listener-service health checks",
        "Uri": "https://demo-event-listener-service-821209474183.europe-west1.run.app/hc"
      }
    ]
  }
}

