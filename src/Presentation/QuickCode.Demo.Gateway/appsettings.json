{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Swagger": {
    "Title": "QuickCode Gateway Api",
    "TermsOfService": "https://www.quickcode.net",
    "Contact": "https://www.quickcode.net",
    "License": "https://www.quickcode.net"
  },
  "RateLimiting": {
    "Enabled": true,
    "ApplyAuthPolicies": true,
    "General": {
      "PermitLimit": 1000,
      "WindowSeconds": 60
    },
    "Auth": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    },
    "Refresh": {
      "PermitLimit": 60,
      "WindowSeconds": 60
    }
  },
  "AllowedHosts": "*"
}