# Local secrets for Docker Compose and dotnet run (copy to .env — never commit .env)
# RSA key pair (base64 DER). Generate with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -outform DER | openssl base64 -A   # -> private (PKCS#8)
#   (derive the SPKI public key from the private key and base64-encode it)
# Only the Gateway gets the private key; modules only get the public key.
GATEWAY_JWT_PRIVATE_KEY=replace-with-base64-pkcs8-private-key
GATEWAY_JWT_PUBLIC_KEY=replace-with-base64-spki-public-key
GATEWAY_INTERNAL_TOKEN_KEY=replace-with-long-random-internal-token-key
# RSA private key for user JWTs (RS256, base64 PKCS#8). Only the Identity module uses it.
USER_JWT_PRIVATE_KEY=replace-with-base64-pkcs8-private-key

PGSQL_PORT=5432
MYSQL_PORT=3306
SQL_PORT=5433
ELASTIC_PORT=9200
KIBANA_PORT=5601
EVENT_LISTENER_PORT=6100
KAFDROP_PORT=9000
KAFKA_PORT=9092
ZOOKEEPER_PORT=2181
GATEWAY_PORT=6060
PORTAL_PORT=6020
